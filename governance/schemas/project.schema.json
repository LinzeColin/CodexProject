{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linzecolin.local/codexproject/governance/project.schema.json",
  "title": "CodexProject Lean v2 project facts",
  "type": "object",
  "required": [
    "schema_version",
    "project_id",
    "project_name",
    "summary",
    "fact_level",
    "features",
    "models",
    "assumptions",
    "formulas",
    "parameters",
    "strategies",
    "validations",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "codexproject.project.v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "fact_level": {
      "$ref": "#/$defs/fact_level"
    },
    "owner_role": {
      "type": "string"
    },
    "current_status": {
      "$ref": "#/$defs/lifecycle_status"
    },
    "limitations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fact_statement"
      }
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feature"
      },
      "uniqueItems": true
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model"
      },
      "uniqueItems": true
    },
    "assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assumption"
      },
      "uniqueItems": true
    },
    "formulas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/formula"
      },
      "uniqueItems": true
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parameter"
      },
      "uniqueItems": true
    },
    "strategies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/strategy"
      },
      "uniqueItems": true
    },
    "validations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation"
      },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      },
      "uniqueItems": true
    },
    "legacy_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/legacy_ref"
      }
    }
  },
  "$defs": {
    "fact_level": {
      "type": "string",
      "enum": ["VERIFIED", "EXTRACTED", "RECONSTRUCTED", "PROPOSED", "UNKNOWN", "NOT_APPLICABLE"]
    },
    "lifecycle_status": {
      "type": "string",
      "enum": ["active", "planned", "deprecated", "blocked", "unknown", "not_applicable"]
    },
    "non_empty_string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fact_statement": {
      "type": "object",
      "required": ["statement", "fact_level", "evidence_refs"],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "fact_level": {
          "$ref": "#/$defs/fact_level"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "unknown_task_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      },
      "additionalProperties": false
    },
    "feature": {
      "type": "object",
      "required": ["feature_id", "name", "description", "status", "fact_level", "evidence_refs"],
      "properties": {
        "feature_id": {
          "type": "string",
          "pattern": "^FEAT-[A-Za-z0-9_.-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/lifecycle_status"
        },
        "fact_level": {
          "$ref": "#/$defs/fact_level"
        },
        "model_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "parameter_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "code_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "test_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      },
      "additionalProperties": false
    },
    "model": {
      "type": "object",
      "required": ["model_id", "name", "purpose", "status", "fact_level", "formula_ids", "parameter_ids", "evidence_refs"],
      "properties": {
        "model_id": {
          "type": "string",
          "pattern": "^MOD-[A-Za-z0-9_.-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/lifecycle_status"
        },
        "fact_level": {
          "$ref": "#/$defs/fact_level"
        },
        "assumption_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "formula_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "parameter_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "input_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "output_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "code_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "test_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      },
      "additionalProperties": false
    },
    "assumption": {
      "type": "object",
      "required": ["assumption_id", "statement", "status", "fact_level", "evidence_refs"],
      "properties": {
        "assumption_id": {
          "type": "string",
          "pattern": "^ASM-[A-Za-z0-9_.-]+$"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/lifecycle_status"
        },
        "fact_level": {
          "$ref": "#/$defs/fact_level"
        },
        "impact_if_false": {
          "type": "string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "unknown_task_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      },
      "additionalProperties": false
    },
    "formula": {
      "type": "object",
      "required": ["formula_id", "model_id", "description", "status", "fact_level", "expression", "variables", "evidence_refs"],
      "properties": {
        "formula_id": {
          "type": "string",
          "pattern": "^FORM-[A-Za-z0-9_.-]+$"
        },
        "model_id": {
          "type": "string",
          "pattern": "^MOD-[A-Za-z0-9_.-]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/lifecycle_status"
        },
        "fact_level": {
          "$ref": "#/$defs/fact_level"
        },
        "expression": {
          "type": "string",
          "minLength": 1
        },
        "variables": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/formula_variable"
          }
        },
        "code_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "test_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      },
      "additionalProperties": false
    },
    "formula_variable": {
      "type": "object",
      "required": ["name", "meaning", "source"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "meaning": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "parameter": {
      "type": "object",
      "required": ["parameter_id", "symbol", "name", "status", "fact_level", "value", "source", "evidence_refs"],
      "properties": {
        "parameter_id": {
          "type": "string",
          "pattern": "^PARAM-[A-Za-z0-9_.-]+$"
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/lifecycle_status"
        },
        "fact_level": {
          "$ref": "#/$defs/fact_level"
        },
        "value": {},
        "unit": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "config_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "code_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "test_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      },
      "additionalProperties": false
    },
    "strategy": {
      "type": "object",
      "required": ["strategy_id", "name", "description", "status", "fact_level", "evidence_refs"],
      "properties": {
        "strategy_id": {
          "type": "string",
          "pattern": "^STRAT-[A-Za-z0-9_.-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/lifecycle_status"
        },
        "fact_level": {
          "$ref": "#/$defs/fact_level"
        },
        "model_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "parameter_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "risk_controls": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["validation_id", "scope", "method", "status", "fact_level", "evidence_refs"],
      "properties": {
        "validation_id": {
          "type": "string",
          "pattern": "^VAL-[A-Za-z0-9_.-]+$"
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/lifecycle_status"
        },
        "fact_level": {
          "$ref": "#/$defs/fact_level"
        },
        "test_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      },
      "additionalProperties": false
    },
    "evidence_ref": {
      "type": "object",
      "required": ["evidence_id", "kind", "ref", "fact_level"],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^EVID-[A-Za-z0-9_.-]+$"
        },
        "kind": {
          "type": "string",
          "enum": ["code", "config", "test", "run_manifest", "ci", "owner", "external", "unknown"]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "fact_level": {
          "$ref": "#/$defs/fact_level"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "legacy_ref": {
      "type": "object",
      "required": ["legacy_path", "replacement_status"],
      "properties": {
        "legacy_path": {
          "type": "string",
          "minLength": 1
        },
        "replacement_status": {
          "type": "string",
          "enum": ["pending", "mapped", "replaced", "archived"]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
