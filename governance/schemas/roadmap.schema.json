{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linzecolin.local/codexproject/governance/roadmap.schema.json",
  "title": "CodexProject Lean v2 roadmap",
  "type": "object",
  "required": [
    "schema_version",
    "roadmap_kind",
    "project_id",
    "total_estimated_hours",
    "current_stage_id",
    "current_phase_id",
    "current_task_id",
    "stages"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "codexproject.roadmap.v1"
    },
    "roadmap_kind": {
      "type": "string",
      "const": "product",
      "description": "Product roadmaps are the only roadmap kind allowed to render into project human entries."
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "total_estimated_hours": {
      "type": "number",
      "minimum": 0
    },
    "completed_estimated_hours": {
      "type": "number",
      "minimum": 0
    },
    "current_stage_id": {
      "type": "string",
      "pattern": "^S[1-9][0-9]*$"
    },
    "current_phase_id": {
      "type": "string",
      "pattern": "^S[1-9][0-9]*P[A-Z]$"
    },
    "current_task_id": {
      "type": "string",
      "pattern": "^S[1-9][0-9]*P[A-Z]T[0-9]{2}$"
    },
    "next_gate_id": {
      "type": "string",
      "minLength": 1
    },
    "stages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stage"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "task_status": {
      "type": "string",
      "enum": ["proposed", "planned", "ready", "in_progress", "blocked", "completed", "rejected", "deprecated"]
    },
    "failure_action": {
      "type": "string",
      "enum": ["remain_in_phase", "remain_in_stage", "blocked", "owner_decision_required", "rollback"]
    },
    "non_empty_string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "estimate": {
      "type": "number",
      "minimum": 0
    },
    "percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "stop_gate": {
      "type": "object",
      "required": ["gate_id", "pass_criteria", "evidence", "failure_action"],
      "properties": {
        "gate_id": {
          "type": "string",
          "minLength": 1
        },
        "pass_criteria": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "evidence": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "failure_action": {
          "$ref": "#/$defs/failure_action"
        },
        "approver": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "acceptance": {
      "type": "object",
      "required": ["acceptance_id", "description", "evidence_refs"],
      "properties": {
        "acceptance_id": {
          "type": "string",
          "pattern": "^ACC-[A-Za-z0-9_.-]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      },
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "required": [
        "task_id",
        "name",
        "objective",
        "status",
        "estimated_hours",
        "estimated_pct",
        "dependencies",
        "acceptance_ids",
        "acceptance",
        "test_commands",
        "test_results",
        "evidence_refs",
        "risks",
        "rollback"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^S[1-9][0-9]*P[A-Z]T[0-9]{2}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/task_status"
        },
        "estimated_hours": {
          "$ref": "#/$defs/estimate"
        },
        "estimated_pct": {
          "$ref": "#/$defs/percentage"
        },
        "dependencies": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "acceptance_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "acceptance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/acceptance"
          }
        },
        "test_commands": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "test_results": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "risks": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "rollback": {
          "type": "string",
          "minLength": 1
        },
        "completed_version": {
          "type": "string"
        },
        "completed_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        }
      },
      "additionalProperties": false
    },
    "phase": {
      "type": "object",
      "required": [
        "phase_id",
        "name",
        "objective",
        "status",
        "estimated_hours",
        "estimated_pct",
        "stop_conditions",
        "stop_gate",
        "tasks"
      ],
      "properties": {
        "phase_id": {
          "type": "string",
          "pattern": "^S[1-9][0-9]*P[A-Z]$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/task_status"
        },
        "estimated_hours": {
          "$ref": "#/$defs/estimate"
        },
        "estimated_pct": {
          "$ref": "#/$defs/percentage"
        },
        "stop_conditions": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "stop_gate": {
          "$ref": "#/$defs/stop_gate"
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "stage": {
      "type": "object",
      "required": [
        "stage_id",
        "name",
        "person_goal",
        "status",
        "estimated_hours",
        "estimated_pct",
        "stop_conditions",
        "stop_gate",
        "phases"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "pattern": "^S[1-9][0-9]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "person_goal": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/task_status"
        },
        "estimated_hours": {
          "$ref": "#/$defs/estimate"
        },
        "estimated_pct": {
          "$ref": "#/$defs/percentage"
        },
        "stop_conditions": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "stop_gate": {
          "$ref": "#/$defs/stop_gate"
        },
        "phases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/phase"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
