{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linzecolin.local/codexproject/governance/incident_response.schema.json",
  "title": "CodexProject incident response record",
  "type": "object",
  "required": [
    "project_path",
    "incident_id",
    "affected_version",
    "target_rollback_version",
    "incident_time",
    "impact_scope",
    "symptoms",
    "evidence_refs",
    "affected_models",
    "affected_formulas",
    "affected_parameters",
    "root_cause_status",
    "action_type",
    "validation_commands",
    "validation_results",
    "follow_up_task_id",
    "fact_level"
  ],
  "properties": {
    "project_path": {"type": "string", "minLength": 1},
    "incident_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+$"},
    "affected_version": {"type": "string", "minLength": 1},
    "target_rollback_version": {"type": "string", "minLength": 1},
    "incident_time": {"type": "string", "minLength": 1},
    "impact_scope": {"type": "string", "minLength": 1},
    "symptoms": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "evidence_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "affected_models": {"type": "array", "items": {"type": "string"}},
    "affected_formulas": {"type": "array", "items": {"type": "string"}},
    "affected_parameters": {"type": "array", "items": {"type": "string"}},
    "recent_changes": {"type": "array", "items": {"type": "string"}},
    "data_compatibility_risk": {"type": "string"},
    "root_cause_status": {"type": "string", "enum": ["unknown", "hypothesized", "confirmed", "not_applicable"]},
    "root_cause_statement": {"type": "string"},
    "action_type": {"type": "string", "enum": ["hotfix", "rollback", "no_change"]},
    "files_changed": {"type": "array", "items": {"type": "string"}},
    "model_delta": {"type": "string"},
    "parameter_delta": {"type": "string"},
    "version_delta": {"type": "string"},
    "validation_commands": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "validation_results": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "incident_status": {"type": "string", "enum": ["open", "mitigated", "resolved", "rejected"]},
    "remaining_impact": {"type": "string"},
    "follow_up_task_id": {"type": "string", "minLength": 1},
    "fact_level": {"type": "string", "enum": ["EXTRACTED", "RECONSTRUCTED", "PROPOSED", "UNKNOWN", "NOT_APPLICABLE"]}
  },
  "additionalProperties": true
}
