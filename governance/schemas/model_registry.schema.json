{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linzecolin.local/codexproject/governance/model_registry.schema.json",
  "title": "CodexProject model registry",
  "type": "object",
  "required": ["governance_spec_version", "project_id", "models"],
  "properties": {
    "governance_spec_version": {"type": "string"},
    "project_id": {"type": "string", "minLength": 1},
    "assumptions": {
      "type": "array",
      "items": {"$ref": "#/$defs/assumption"}
    },
    "models": {
      "type": "array",
      "items": {"$ref": "#/$defs/model"},
      "uniqueItems": true
    }
  },
  "$defs": {
    "fact_level": {
      "type": "string",
      "enum": ["EXTRACTED", "RECONSTRUCTED", "PROPOSED", "UNKNOWN", "NOT_APPLICABLE"]
    },
    "assumption": {
      "type": "object",
      "required": ["assumption_id", "statement", "fact_level", "status", "evidence_refs"],
      "properties": {
        "assumption_id": {"type": "string", "pattern": "^ASM-[0-9]{3,}$"},
        "statement": {"type": "string", "minLength": 1},
        "why_needed": {"type": "string"},
        "scope": {"type": "string"},
        "impact_if_violated": {"type": "string"},
        "validation_method": {"type": "string"},
        "status": {"type": "string", "enum": ["active", "planned", "deprecated", "not_applicable", "unknown"]},
        "fact_level": {"$ref": "#/$defs/fact_level"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "unknown_task_ids": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "model": {
      "type": "object",
      "required": [
        "model_id",
        "name",
        "kind",
        "purpose",
        "owner",
        "status",
        "fact_level",
        "model_version",
        "assumptions",
        "formula_ids",
        "parameter_ids",
        "inputs",
        "outputs",
        "code_refs",
        "test_refs",
        "evidence_refs"
      ],
      "properties": {
        "model_id": {"type": "string", "pattern": "^MOD-[0-9]{3,}$"},
        "name": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "minLength": 1},
        "purpose": {"type": "string", "minLength": 1},
        "owner": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["active", "planned", "deprecated", "not_applicable"]},
        "fact_level": {"$ref": "#/$defs/fact_level"},
        "model_version": {"type": "string"},
        "assumptions": {"type": "array", "items": {"$ref": "#/$defs/assumption"}},
        "assumption_ids": {"type": "array", "items": {"type": "string"}},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "outputs": {"type": "array", "items": {"type": "string"}},
        "methodology": {"type": "string"},
        "formula_ids": {"type": "array", "items": {"type": "string"}},
        "parameter_ids": {"type": "array", "items": {"type": "string"}},
        "code_refs": {"type": "array", "items": {"type": "string"}},
        "test_refs": {"type": "array", "items": {"type": "string"}},
        "fallback_policy": {"type": "string"},
        "risk_controls": {"type": "array", "items": {"type": "string"}},
        "failure_modes": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "unknown_task_ids": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
