{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodexProject Local Governance Run Receipt",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "repository",
    "workspace_root",
    "base_commit",
    "source_tree_hash",
    "hook_started_at",
    "hook_completed_at",
    "commands",
    "return_codes",
    "final_status",
    "changed_files",
    "generated_views",
    "fact_level"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "repository": { "type": "string", "minLength": 1 },
    "workspace_root": { "type": "string", "minLength": 1 },
    "base_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "source_tree_hash": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "hook_started_at": { "type": "string", "minLength": 1 },
    "hook_completed_at": { "type": "string", "minLength": 1 },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "argv", "return_code"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "argv": { "type": "array", "items": { "type": "string" } },
          "return_code": { "type": "integer" }
        }
      }
    },
    "return_codes": { "type": "array", "items": { "type": "integer" } },
    "final_status": { "type": "string", "enum": ["PASS", "FAIL"] },
    "changed_projects": { "type": "array", "items": { "type": "string" } },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "generated_views": { "type": "array", "items": { "type": "string" } },
    "fact_level": { "type": "string", "enum": ["EXTRACTED"] }
  }
}
