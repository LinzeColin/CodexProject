{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linzecolin.local/codexproject/governance/formula_registry.schema.json",
  "title": "CodexProject formula registry",
  "type": "object",
  "required": ["governance_spec_version", "project_id", "formulas"],
  "properties": {
    "governance_spec_version": {"type": "string"},
    "project_id": {"type": "string", "minLength": 1},
    "formulas": {
      "type": "array",
      "items": {"$ref": "#/$defs/formula"},
      "uniqueItems": true
    }
  },
  "$defs": {
    "variable": {
      "type": "object",
      "required": ["name", "data_type", "unit", "input_domain"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "data_type": {"type": "string", "minLength": 1},
        "unit": {"type": "string", "minLength": 1},
        "input_domain": {"type": "string", "minLength": 1},
        "description": {"type": "string"}
      },
      "additionalProperties": true
    },
    "formula": {
      "type": "object",
      "required": [
        "formula_id",
        "model_id",
        "assumption_ids",
        "status",
        "expression",
        "variables",
        "constraints",
        "missing_policy",
        "output_range",
        "code_refs",
        "test_refs",
        "evidence_refs"
      ],
      "properties": {
        "formula_id": {"type": "string", "pattern": "^FORM-[0-9]{3,}$"},
        "model_id": {"type": "string", "pattern": "^MOD-[0-9]{3,}$"},
        "assumption_ids": {"type": "array", "items": {"type": "string"}},
        "status": {"type": "string", "enum": ["active", "planned", "deprecated", "not_applicable"]},
        "expression": {"type": "string", "minLength": 1},
        "variables": {"type": "array", "items": {"$ref": "#/$defs/variable"}},
        "constraints": {"type": "array", "items": {"type": "string"}},
        "missing_policy": {"type": "string", "minLength": 1},
        "normalization": {"type": "string"},
        "output_range": {"type": "string", "minLength": 1},
        "code_refs": {"type": "array", "items": {"type": "string"}},
        "test_refs": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "unknown_task_ids": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
