{
  "name": "@openaidatabase/memory-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "tsc -b --pretty false",
    "validate:memory-river-evidence": "node scripts/validate_memory_river_evidence_layers.mjs",
    "validate:memory-river-interaction": "node scripts/validate_memory_river_interaction.mjs",
    "validate:memory-river-rendering": "node scripts/validate_memory_river_rendering.mjs",
    "validate:memory-river-stage5": "node scripts/validate_memory_river_stage5.mjs",
    "validate:inspector-proposal": "node scripts/validate_inspector_proposal.mjs",
    "validate:shared-state": "node --experimental-strip-types scripts/validate_shared_state_store.mjs",
    "validate:stage6": "node scripts/validate_memory_atlas_stage6.mjs",
    "validate:stage7-visual": "node scripts/validate_stage7_visual_acceptance.cjs",
    "validate:stage7-performance": "node scripts/validate_stage7_performance_acceptance.cjs",
    "validate:stage7-privacy-accessibility": "node scripts/validate_stage7_privacy_accessibility.cjs",
    "validate:stage7": "node scripts/validate_memory_atlas_stage7.mjs",
    "validate:stage8-local-app": "node scripts/validate_stage8_local_app_packaging.cjs",
    "validate:memory-starfield-interaction": "node scripts/validate_memory_starfield_interaction.mjs",
    "validate:memory-starfield-mapping": "node scripts/validate_memory_starfield_mapping.mjs",
    "validate:universe-state-spike": "node --experimental-strip-types scripts/validate_universe_state_spike.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "d3": "^7.9.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "three": "^0.181.2",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.181.0",
    "typescript": "^5.9.3"
  }
