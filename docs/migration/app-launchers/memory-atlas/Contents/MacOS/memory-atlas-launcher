exec >> "$LOG_FILE" 2>&1

notify_status() {
  local message="$1"
  /usr/bin/osascript \
    -e 'on run argv' \
    -e 'display notification (item 1 of argv) with title "Memory Atlas"' \
    -e 'end run' \
    -- "$message" >/dev/null 2>&1 &!
}

notify_error() {
  local message="$1"
  /usr/bin/osascript \
    -e 'on run argv' \
    -e 'display dialog (item 1 of argv) buttons {"OK"} default button "OK" with icon caution' \
    -e 'end run' \
    -- "$message" >/dev/null 2>&1 || true
}

